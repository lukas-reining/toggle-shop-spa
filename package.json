{
  "name": "toggle-shop-spa",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run start:dev --workspace @toggle-shop/api",
    "dev:web": "npm run dev --workspace @toggle-shop/web",
    "build": "npm run build --workspace @toggle-shop/shared && npm run build --workspace @toggle-shop/api && npm run build --workspace @toggle-shop/web",
    "test": "npm run test --workspace @toggle-shop/web",
    "lint": "npm-run-all --parallel lint:*",
    "lint:api": "npm run lint --workspace @toggle-shop/api --if-present",
    "lint:web": "npm run lint --workspace @toggle-shop/web --if-present",
    "generate-flags": "make generate-flags",
    "flagd": "make start-flagd"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
