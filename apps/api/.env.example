# The port the API listens on
PORT=3001

# Allowed CORS origin for the SPA
CORS_ORIGIN=http://localhost:3000

# flagd connection (in-process provider). Used by @openfeature/flagd-provider.
FLAGD_HOST=localhost
FLAGD_PORT=8015

# The signal-specific OTEL endpoints (optional)
OTLP_TRACE_URL=
OTLP_METRICS_URL=
OTLP_LOGS_URL=

# Sets the authorization header for the OTLP requests
OTLP_AUTHORIZATION=
