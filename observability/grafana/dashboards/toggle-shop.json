{
  "uid": "toggle-shop-demo",
  "title": "ToggleShop: Flag Impact (Technical + Business)",
  "description": "Live impact of feature-flag changes on telemetry. Top row = technical (latency/errors), bottom row = business (orders/revenue).",
  "tags": [
    "toggle-shop",
    "openfeature",
    "demo"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-10m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m"
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Technical impact: use-distributed-db / use-secure-protocol",
      "collapsed": false,
      "datasource": null,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP request latency p95 by route",
      "description": "p95 server-side latency. Flipping use-distributed-db (SQLite ↔ Postgres) and use-secure-protocol changes this.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_duration_milliseconds_bucket{http_route!=\"/api/health\"}[$__rate_interval])))",
          "legendFormat": "p95 {{http_route}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP throughput & errors by status",
      "description": "Requests/sec split by status code. use-secure-protocol ON makes Postgres node 3 refuse connections → 5xx appear here.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count{http_route!=\"/api/health\"}[$__rate_interval]))",
          "legendFormat": "{{http_status_code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "use-distributed-db: active variant (evals/sec)",
      "description": "Fractional 1:3 split across shoppers. Shows which DB backend traffic is hitting.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (feature_flag_result_variant) (rate(feature_flag_evaluation_success_total{feature_flag_key=\"use-distributed-db\"}[$__rate_interval]))",
          "legendFormat": "{{feature_flag_result_variant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "use-secure-protocol: active variant (evals/sec)",
      "description": "When ON (and distributed-db ON) ~1 in 4 Postgres calls fail.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (feature_flag_result_variant) (rate(feature_flag_evaluation_success_total{feature_flag_key=\"use-secure-protocol\"}[$__rate_interval]))",
          "legendFormat": "{{feature_flag_result_variant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Error traces (5xx)",
      "description": "Failing requests as traces (TraceQL: { status = error }). use-secure-protocol ON makes Postgres node 3 refuse connections, so those spans get status=error. Open a row to see the failing DB span next to the feature_flag.evaluation event naming the active variant.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "refId": "A",
          "queryType": "traceql",
          "query": "{ status = error }",
          "tableType": "traces",
          "limit": 20
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Business impact: offer-free-shipping",
      "collapsed": false,
      "datasource": null,
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Orders per minute by variant",
      "description": "Orders attributed to the offer-free-shipping variant the shopper saw. The headline business metric.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 18,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (feature_flag_variant) (rate(shop_orders_count_total[$__rate_interval])) * 60",
          "legendFormat": "{{feature_flag_variant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Revenue per minute by variant (EUR)",
      "description": "Order value per minute, split by the offer-free-shipping variant.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 18,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (feature_flag_variant) (rate(shop_orders_revenue_EUR_total[$__rate_interval])) * 60",
          "legendFormat": "{{feature_flag_variant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Average order value by variant (EUR)",
      "description": "Revenue ÷ orders per variant.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "interval": "5s",
          "expr": "sum by (feature_flag_variant) (rate(shop_orders_revenue_EUR_total[$__rate_interval])) / clamp_min(sum by (feature_flag_variant) (rate(shop_orders_count_total[$__rate_interval])), 0.0001)",
          "legendFormat": "{{feature_flag_variant}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "offer-free-shipping: orders (on)",
      "description": "Cumulative orders placed while free shipping was ON.",
